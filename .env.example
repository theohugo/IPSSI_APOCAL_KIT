# ============================================================================
# IPSSI_APOCAL_KIT — Variables d'environnement
# ----------------------------------------------------------------------------
# Copier en .env (gitignored) et adapter selon votre équipe :
#   cp .env.example .env
# ============================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=apocal
POSTGRES_USER=apocal
POSTGRES_PASSWORD=apocal-dev-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- LLM (génération des QCM) ---
# Fournisseur de génération. En DÉVELOPPEMENT, gardez "ollama" (gratuit, local,
# données souveraines). Les fournisseurs payants (openai, anthropic) sont prévus
# pour une future version PREMIUM : ne les activez QUE si vous assumez les coûts.
#   ollama | gemini | groq | cerebras | mistral | openrouter | openai | anthropic | mock
LLM_BACKEND=ollama

# -- Ollama (LOCAL, GRATUIT — défaut recommandé) --
OLLAMA_HOST=http://ollama:11434
# mistral:7b retenu au benchmark J2 (ADR-0001) : p95 ~12,5 s (< 15 s), 100 % local.
OLLAMA_MODEL=mistral:7b
# Délai max (s) d'une génération Ollama. Sur CPU, un 8B met souvent 2 à 5 min.
# Augmentez si vos générations échouent en 502 (timeout) ; réduisez avec un GPU.
# OLLAMA_TIMEOUT=600

# -- OpenAI (PAYANT — laissez vide en dev) --
# Clé : https://platform.openai.com/api-keys   |   Modèles : gpt-4o-mini, gpt-4o…
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# -- Anthropic / Claude (PAYANT — laissez vide en dev) --
# Clé : https://console.anthropic.com/   |   Modèles : claude-3-5-haiku, claude-3-5-sonnet…
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# -- Google Gemini (cloud, FREE TIER — idéal pour tester une API sans CB) --
# Clé GRATUITE : https://aistudio.google.com/apikey   |   Modèles : gemini-1.5-flash, gemini-1.5-pro…
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash

# -- Groq (cloud, format OpenAI, ultra-rapide, FREE TIER) --
# Clé GRATUITE : https://console.groq.com/keys   |   Modèles : llama-3.3-70b-versatile, llama-3.1-8b-instant…
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# -- Cerebras Cloud (cloud, format OpenAI, ultra-rapide, FREE TIER) --
# Clé GRATUITE : https://cloud.cerebras.ai/   |   Modèles : llama-3.3-70b, llama3.1-8b…
# CEREBRAS_API_KEY=csk-...
# CEREBRAS_MODEL=llama-3.3-70b

# -- Mistral AI (cloud, format OpenAI, fournisseur EUROPÉEN, free tier) --
# Clé : https://console.mistral.ai/   |   Modèles : mistral-small-latest, mistral-large-latest…
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-small-latest

# -- OpenRouter (cloud, passerelle multi-modèles, format OpenAI) --
# Clé : https://openrouter.ai/keys   |   Modèle "editeur/modele" (suffixe ":free" pour les gratuits)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Délai max (s) pour les API cloud, bien plus rapides qu'un CPU local.
# LLM_API_TIMEOUT=60

# --- Email (Brevo) ---
# ============================================================================
#  ⚠️  CONFIG BREVO DE FORMATION — CLÉ TEMPORAIRE, FOURNIE POUR APOCAL'IPSSI  ⚠️
# ----------------------------------------------------------------------------
# Cette clé SMTP appartient à un compte Brevo JETABLE dédié à la semaine de
# formation. Elle est partagée ici pour que les équipes testent l'envoi d'email
# sans créer de compte. ELLE EXPIRERA après la formation.
#
# 🚫 LEÇON DE SÉCURITÉ : on ne met JAMAIS un vrai secret dans un fichier
#    versionné (surtout dans un repo PUBLIC). C'est toléré ICI uniquement parce
#    que la clé est jetable et temporaire. Pour un vrai projet, chacun met sa
#    propre clé dans son .env LOCAL (gitignored), jamais dans .env.example.
#
# Quand la clé aura expiré : laissez ces champs VIDES -> les emails repassent en
# mode console (affichés dans les logs). Ou mettez votre propre clé Brevo.
# (LOGIN = identifiant xxxxx@smtp-brevo.com affiché sur la page SMTP de Brevo,
#  PAS votre email de compte. https://app.brevo.com/settings/keys/smtp)
# ============================================================================
BREVO_SMTP_KEY=xsmtpsib-1c81465a9155a2d7b3276d90aa043e7f988753a8bbbcdf8d9fabe7d89456c57d-rde1hxJfkCUCM5LE
BREVO_SMTP_LOGIN=ada68d001@smtp-brevo.com
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
DEFAULT_FROM_EMAIL=EduTutor IA <contact@elafrit.com>
# URL du frontend (liens dans les emails) — ajustez si FRONTEND_HOST_PORT change
# FRONTEND_URL=http://localhost:3000

# --- React (Vite) ---
# Note : Vite remplace cette variable au BUILD (ou au démarrage du dev-server),
# PAS au runtime. En dev (npm run dev via docker compose), elle est lue ici.
# Pour un build de production (docker build), passez-la en ARG/ENV au build,
# sinon le bundle figera le fallback http://localhost:8000/api.
VITE_API_BASE_URL=http://localhost:8000/api

# --- Ports hôte (à changer si conflit avec un service local) ---
# Ne décommentez que si docker compose up échoue avec « port already allocated ».
# Le réseau Docker interne reste sur 5432 / 3000.
# POSTGRES_HOST_PORT=5433    # par défaut : 5432
# FRONTEND_HOST_PORT=3002    # par défaut : 3000
#   -> le CORS du backend autorise automatiquement ce port (cf. settings.py),
#      aucune autre modification n'est nécessaire en cas de changement.
